{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vibehack-backend.up.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://vibehack-backend.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
